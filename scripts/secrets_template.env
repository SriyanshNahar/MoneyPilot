# Copy this file to scripts/secrets.env (gitignored), fill in real values,
# then run:
#   supabase secrets set --env-file scripts/secrets.env
#
# scripts/secrets.env itself is never committed — only this template is.

# AI Coach (ai-chat function) — Claude, get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Razorpay (razorpay-create-order / razorpay-verify-payment) — Dashboard → Settings → API Keys
# Use LIVE keys only once you're ready to accept real payments; use TEST keys
# (rzp_test_...) while developing.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Razorpay webhook (razorpay-webhook function) — Dashboard → Settings →
# Webhooks → Add New Webhook. Set the webhook URL to:
#   https://rfrddfjtmrtfhqlvvqzf.supabase.co/functions/v1/razorpay-webhook
# subscribe to the "payment.captured" event, generate a secret there, and
# paste that SAME secret here.
RAZORPAY_WEBHOOK_SECRET=

# Alerts (send-alert function) — optional, only needed for email alerts.
# Get a key at https://resend.com/api-keys. SMS/WhatsApp stay stubbed
# ("Connect Twilio to enable") until you wire a Twilio account — matching
# the original React app's alerts.functions.ts, which is stubbed the same way.
RESEND_API_KEY=
